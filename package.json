{
  "name": "superflux-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build",
    "build:chrome": "tsc -b && cross-env BROWSER=chrome vite build",
    "build:firefox": "tsc -b && cross-env BROWSER=firefox vite build",
    "pack:chrome": "npm run build:chrome && node scripts/pack.js chrome",
    "pack:firefox": "npm run build:firefox && node scripts/pack.js firefox",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^6.3.0"
  }
}
